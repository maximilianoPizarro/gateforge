FROM scratch
LABEL name="gateforge-devhub-plugin" \
      version="0.1.9" \
      summary="GateForge Developer Hub Dynamic Plugin" \
      description="Native RHDH dynamic backend plugin that receives GateForge migration events and registers Kuadrant/Connectivity Link entities in the Backstage catalog" \
      io.k8s.display-name="GateForge DevHub Dynamic Plugin" \
      io.openshift.tags="gateforge,developer-hub,backstage,kuadrant,connectivity-link,dynamic-plugin" \
      vendor="GateForge"
COPY dist-dynamic/ /gateforge-backstage-plugin-catalog-backend-module-gateforge/
